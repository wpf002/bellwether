# ---- Database ----
DATABASE_URL=postgresql://bellwether:bellwether@localhost:5432/bellwether

# ---- Redis (BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- LLM (structured extraction ONLY — never scoring/decisions) ----
ANTHROPIC_API_KEY=
# Extraction runs once per (raw record × entity kind). Defaults to the most
# capable model; set to claude-haiku-4-5 or claude-sonnet-4-6 to cut cost.
EXTRACT_MODEL=claude-opus-4-8

# ---- API ----
API_PORT=4000
API_HOST=0.0.0.0
LOG_LEVEL=info

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- Scraper etiquette (legal posture — see COMPLIANCE.md) ----
SCRAPER_USER_AGENT=BellwetherBot/0.1 (+https://example.com/bot)
SCRAPER_RESPECT_ROBOTS=true
SCRAPER_DEFAULT_RATE_LIMIT_MS=2000
SCRAPER_MAX_CONCURRENCY=2
# Cap records kept per feed fetch — a weekly digest shouldn't ingest a full archive.
SCRAPER_MAX_ITEMS=25
