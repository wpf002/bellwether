{
  "name": "bellwether",
  "version": "0.0.0",
  "private": true,
  "description": "Industry-aware market intelligence platform. Scrapes public sources, structures them through an auditable transform chain, and tells you where a market is heading.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @bellwether/db db:generate",
    "db:migrate": "pnpm --filter @bellwether/db db:migrate",
    "db:studio": "pnpm --filter @bellwether/db db:studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0"
  }
}
